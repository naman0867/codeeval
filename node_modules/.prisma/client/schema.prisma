// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CANDIDATE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions     Submission[]
  sessions        InterviewSession[] @relation("CandidateSessions")
  createdSessions InterviewSession[] @relation("InterviewerSessions")

  @@map("users")
}

enum Role {
  ADMIN
  INTERVIEWER
  CANDIDATE
}

// ─── Problems ────────────────────────────────────────────────────────────────

model Problem {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String // Markdown
  difficulty  Difficulty @default(MEDIUM)
  timeLimit   Int        @default(2000) // ms
  memoryLimit Int        @default(256) // MB
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  testCases   TestCase[]
  starterCode StarterCode[]
  submissions Submission[]
  sessions    InterviewSession[]

  @@map("problems")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model TestCase {
  id        String  @id @default(uuid())
  problemId String
  input     String
  expected  String
  isHidden  Boolean @default(false) // hidden = only run on final submit
  order     Int     @default(0)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

model StarterCode {
  id        String   @id @default(uuid())
  problemId String
  language  Language
  code      String

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([problemId, language])
  @@map("starter_codes")
}

enum Language {
  PYTHON
  JAVASCRIPT
  JAVA
  CPP
}

// ─── Submissions ─────────────────────────────────────────────────────────────

model Submission {
  id        String           @id @default(uuid())
  userId    String
  problemId String
  sessionId String?
  language  Language
  code      String
  status    SubmissionStatus @default(PENDING)
  verdict   Verdict?
  score     Float? // 0.0 – 1.0 (fraction of test cases passed)
  runtime   Int? // ms
  memory    Int? // MB
  error     String?
  createdAt DateTime         @default(now())

  user    User              @relation(fields: [userId], references: [id])
  problem Problem           @relation(fields: [problemId], references: [id])
  session InterviewSession? @relation(fields: [sessionId], references: [id])
  results TestResult[]

  @@map("submissions")
}

enum SubmissionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum Verdict {
  AC // Accepted
  WA // Wrong Answer
  TLE // Time Limit Exceeded
  MLE // Memory Limit Exceeded
  RE // Runtime Error
  CE // Compile Error
}

model TestResult {
  id           String  @id @default(uuid())
  submissionId String
  testCaseId   String
  passed       Boolean
  actualOutput String?
  runtime      Int? // ms
  memory       Int? // MB

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("test_results")
}

// ─── Interview Sessions ───────────────────────────────────────────────────────

model InterviewSession {
  id            String        @id @default(uuid())
  candidateId   String
  interviewerId String
  problemId     String
  token         String        @unique @default(uuid()) // shareable link token
  status        SessionStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int           @default(60)
  notes         String?
  createdAt     DateTime      @default(now())

  candidate   User         @relation("CandidateSessions", fields: [candidateId], references: [id])
  interviewer User         @relation("InterviewerSessions", fields: [interviewerId], references: [id])
  problem     Problem      @relation(fields: [problemId], references: [id])
  submissions Submission[]

  @@map("interview_sessions")
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}
