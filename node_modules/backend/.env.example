# Database
DATABASE_URL="postgresql://user:password@localhost:5432/codeeval"

# Redis (for Bull queue)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Execution limits (per submission)
EXEC_TIMEOUT_MS=5000
EXEC_MEMORY_MB=256
EXEC_CPU_PERIOD=100000
EXEC_CPU_QUOTA=50000

# AWS S3 (for test case files — optional in dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=codeeval-testcases
